# ── Dev mail server (Mailpit via ./dev.sh mail) ──────────────────────────
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=Dev Test <dev@localhost>
SMTP_TO=dev@localhost
SMTP_SECURITY=plain

# ── Production (uncomment and fill in) ──────────────────────────────────
# SMTP_HOST=mail.fazuh.com
# SMTP_PORT=587
# SMTP_USERNAME=site@fazuh.com
# SMTP_PASSWORD=secretpassword
# SMTP_FROM=FAZuH Site <site@fazuh.com>
# SMTP_TO=mail@fazuh.com
# SMTP_SECURITY=starttls

# ── General ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
DEFAULT_LOG_DIR=./logs
LOG_FILENAME=app.log

HTTP_BIND=127.0.0.1:8080
